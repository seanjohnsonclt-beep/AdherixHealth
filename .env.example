# Adherix env vars. Copy to .env.local for dev.

# Postgres (Supabase or local)
DATABASE_URL=postgres://user:pass@localhost:5432/adherix

# Supabase (auth)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_DEFAULT_FROM=+15555550100

# App
APP_URL=http://localhost:3000
DEFAULT_TIMEZONE=America/New_York

# For local cron loop
TICK_INTERVAL_SECONDS=60

# For Vercel cron route (production)
CRON_SECRET=changeme
